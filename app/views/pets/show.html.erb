<div class="container mt-5">
  <h1><%= @pet.name.capitalize %>  <small>(<%= @pet.breed %>)</small></h1>

  <p>Address:  <%= @pet.address %></p>
  <p>Found on:  <%= @pet.found_date %></p>

  <%= link_to "See all lost pet's", pets_path%>
  <%= link_to "Edit pet's info", edit_pet_path(@pet) %>
  <%= link_to "Delete pet",
    pet_path(@pet),
    data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}
  %>
</div>
